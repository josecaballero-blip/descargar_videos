# 🤖 Nova Downloader Bot Configuration

# Telegram Bot Token (Get it from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Environment (development | production)
NODE_ENV=development

# Port for Express server
PORT=3000

# Webhook URL (Required for production/Vercel)
# Example: https://nova-downloader-bot.vercel.app
WEBHOOK_URL=

# Cobalt API URL (Use a reliable public instance or self-host)
# Defaults to https://api.cobalt.tools
COBALT_API_URL=https://api.cobalt.tools

# Admin User IDs (Comma-separated Telegram IDs, e.g., 12345678,87654321)
ADMIN_USER_IDS=

# Default Language (es | en)
DEFAULT_LANGUAGE=es
